erDiagram

    %% ─── INSTITUTION & CONFIGURATION ───────────────────────────────────────

    INSTITUTION {
        uuid        id PK
        string      name
        string      country
        string      primary_standard        "CAP | RCPath | RCPA | ICCR"
        string      secondary_standards     "JSON array"
        string      ajcc_edition            "e.g. AJCC 8th"
        string      tnm_edition             "e.g. UICC 8th"
        jsonb       ai_phase1_config        "Phase 1 AI behavior toggles"
        jsonb       ai_phase2_config        "Phase 2 AI behavior toggles"
        timestamp   created_at
        timestamp   updated_at
    }

    INSTITUTION_LICENSE {
        uuid        id PK
        uuid        institution_id FK
        string      standard                "CAP | RCPath | RCPA | ICCR"
        date        effective_date
        date        expiry_date
        boolean     is_active
        timestamp   created_at
    }

    %% ─── TEMPLATE LIBRARY ──────────────────────────────────────────────────

    SYNOPTIC_TEMPLATE {
        uuid        id PK
        string      template_key            "e.g. BREAST-INV-001"
        string      standard                "CAP | RCPath | RCPA | ICCR"
        string      protocol_id             "e.g. BREAST.4.3.0.1"
        string      version                 "e.g. 4.3.0.1"
        string      organ_site              "e.g. Breast"
        string      procedure_type          "e.g. Excision | Mastectomy"
        string      cancer_type
        date        effective_date
        date        deprecated_date
        string      lifecycle_state         "Draft | Active | Deprecated | Retired"
        string      change_log_summary
        uuid        superseded_by_id FK     "points to newer version"
        uuid        created_by_id FK
        timestamp   created_at
        timestamp   updated_at
    }

    TEMPLATE_SECTION {
        uuid        id PK
        uuid        template_id FK
        string      section_id              "e.g. S1"
        string      section_name            "e.g. Specimen"
        integer     display_order
        boolean     is_required
    }

    TEMPLATE_FIELD {
        uuid        id PK
        uuid        section_id FK
        string      field_id                "e.g. F1.1"
        string      field_name              "e.g. Tumor Size"
        string      field_type              "text | dropdown | multi_select | numeric | date | boolean | composite"
        boolean     is_required
        boolean     is_conditionally_required
        string      condition_logic         "JSON rule expression"
        string      unit
        string      validation_rule
        integer     max_length
        jsonb       allowed_values          "for dropdown/multi_select"
        jsonb       standard_mapping        "CAP/RCPath/ICCR label per standard"
        jsonb       unit_conversion         "unit per standard"
        integer     display_order
    }

    TEMPLATE_VALIDATION_RULE {
        uuid        id PK
        uuid        template_id FK
        string      rule_id
        string      tier                    "1_hard_error | 2_warning | 3_custom"
        string      name
        string      condition_logic
        string      action                  "block | warn | notify | flag"
        string      message
        string      source                  "CAP | clinical_logic | institutional"
        string      rationale
        boolean     is_enabled
        integer     override_count
        timestamp   created_at
        timestamp   updated_at
    }

    INSTITUTION_CUSTOM_RULE {
        uuid        id PK
        uuid        institution_id FK
        uuid        template_id FK
        string      rule_id
        string      name
        string      condition_logic
        string      action
        string      severity                "error | warning | info"
        boolean     is_enabled
        uuid        created_by_id FK
        timestamp   created_at
    }

    TERMINOLOGY_MAPPING {
        uuid        id PK
        string      concept_key             "e.g. LYMPHOVASCULAR_INVASION"
        string      standard                "CAP | RCPath | RCPA | ICCR"
        string      standard_label          "standard-specific field name"
        jsonb       value_map               "canonical_value → standard_value"
    }

    %% ─── CASE & SPECIMEN ────────────────────────────────────────────────────

    CASE {
        uuid        id PK
        uuid        institution_id FK
        string      accession_number
        string      mrn                     "PHI - encrypted"
        string      patient_name            "PHI - encrypted"
        date        dob                     "PHI - encrypted"
        string      case_status             "In Progress | Signed Out | Amended"
        boolean     has_frozen_section
        string      frozen_section_diagnosis
        boolean     has_final_diagnosis
        timestamp   frozen_section_at
        timestamp   final_diagnosis_at
        timestamp   accessioned_at
        timestamp   grossed_at
        timestamp   signed_out_at
        uuid        signout_pathologist_id FK
        timestamp   created_at
        timestamp   updated_at
    }

    SPECIMEN {
        uuid        id PK
        uuid        case_id FK
        string      specimen_label          "e.g. Part A"
        string      specimen_type           "e.g. Breast, left, partial mastectomy"
        string      organ_site
        string      procedure_type
        string      cpt_code
        string      clinical_history
        string      ordering_physician
        string      ordering_specialty
        integer     display_order
    }

    LIS_EVENT {
        uuid        id PK
        uuid        case_id FK
        string      event_type              "accessioned | gross_completed | micro_updated | signed_out | amended"
        string      hl7_message_type        "ORU^R01 | ADT | ORM"
        jsonb       payload
        timestamp   received_at
        boolean     processed
        timestamp   processed_at
    }

    %% ─── PROTOCOL PRE-SELECTION ─────────────────────────────────────────────

    PROTOCOL_PRESELECTION {
        uuid        id PK
        uuid        case_id FK
        uuid        specimen_id FK
        uuid        suggested_template_id FK
        float       confidence_score
        string      reasoning
        jsonb       alternate_template_ids
        jsonb       data_sources_used       "specimenType | clinicalHistory | cptCode | etc"
        string      trigger_phase           "accessioning | gross | micro"
        boolean     confirmed_by_user
        boolean     changed_by_user
        uuid        final_template_id FK
        timestamp   created_at
    }

    %% ─── SYNOPTIC INSTANCE & VERSIONING ─────────────────────────────────────

    SYNOPTIC_REPORT {
        uuid        id PK
        uuid        case_id FK
        uuid        specimen_id FK
        uuid        active_version_id FK    "points to current SynopticVersion"
        string      status                  "Draft | Under Review | Approved | Finalized | Amended | Archived"
        boolean     is_preliminary          "true if based on frozen section"
        string      synoptic_based_on       "frozen | final | both"
        uuid        created_by_id FK
        timestamp   created_at
        timestamp   finalized_at
    }

    SYNOPTIC_VERSION {
        uuid        id PK
        uuid        synoptic_report_id FK
        uuid        template_id FK
        integer     version_number          "1, 2, 3..."
        string      version_label           "v1-Manual | v2-AIUpdate | v3-Amendment"
        string      generator               "AI_Phase1 | AI_Phase2 | Manual | Amendment"
        string      trigger_type            "Gross | Microscopic | User | Amendment"
        string      status                  "Draft | Active | Superseded | Archived"
        float       overall_confidence      "weighted score 0.0-1.0"
        uuid        gross_lis_event_id FK   "LIS event that triggered Phase 1"
        uuid        micro_lis_event_id FK   "LIS event that triggered Phase 2"
        string      template_version_used   "snapshot of protocol version at time of generation"
        uuid        created_by_id FK        "user or system"
        timestamp   created_at
        boolean     is_locked               "true after finalization/sign-out"
    }

    SYNOPTIC_FIELD_VALUE {
        uuid        id PK
        uuid        synoptic_version_id FK
        uuid        template_field_id FK
        string      field_id                "denormalized for query convenience"
        string      value
        string      value_display           "human-readable / standard-specific label"
        string      provenance              "AI_Phase1 | AI_Phase2 | Pathologist | System"
        float       ai_confidence           "0.0-1.0, null if not AI-filled"
        string      ai_source_text          "excerpt from gross/micro that supported this value"
        string      ai_reasoning
        boolean     pathologist_confirmed
        boolean     pathologist_overridden
        string      original_ai_value       "preserved if pathologist overrode"
        string      conflict_flag           "null | minor | moderate | major"
        string      special_value           "CBD | NA | blank"
        timestamp   confirmed_at
        uuid        confirmed_by_id FK
    }

    %% ─── AI CONFIDENCE SNAPSHOT ─────────────────────────────────────────────

    AI_CONFIDENCE_SNAPSHOT {
        uuid        id PK
        uuid        synoptic_version_id FK
        float       overall_confidence
        integer     fields_total
        integer     fields_ai_populated
        integer     fields_high_confidence      ">=0.90"
        integer     fields_medium_confidence    "0.50-0.89"
        integer     fields_low_confidence       "<0.50"
        integer     fields_with_conflicts
        jsonb       per_field_scores
        string      protocol_selection_confidence
        string      protocol_selection_reasoning
        timestamp   calculated_at
    }

    %% ─── APPROVAL WORKFLOW ──────────────────────────────────────────────────

    SYNOPTIC_APPROVAL {
        uuid        id PK
        uuid        synoptic_report_id FK
        uuid        synoptic_version_id FK
        uuid        submitted_by_id FK      "Resident/Fellow"
        uuid        reviewer_id FK          "Attending"
        string      status                  "Pending | Approved | Rejected | Returned"
        text        reviewer_notes
        timestamp   submitted_at
        timestamp   reviewed_at
    }

    %% ─── AUDIT LOG ──────────────────────────────────────────────────────────

    AUDIT_LOG {
        uuid        id PK
        uuid        institution_id FK
        uuid        case_id FK
        uuid        synoptic_report_id FK
        uuid        synoptic_version_id FK
        uuid        user_id FK
        string      user_role
        string      action_type             "generate | edit | finalize | view | override | approve | amend"
        string      trigger_type            "Gross | Microscopic | Manual | System"
        uuid        template_id FK
        string      template_version
        jsonb       protocol_changes        "added/removed protocols"
        jsonb       field_changes           "array of {field, before, after}"
        jsonb       ai_confidence_snapshot
        string      ip_address
        string      device_info
        string      session_id
        timestamp   created_at              "immutable"
    }

    %% ─── USERS & ROLES ───────────────────────────────────────────────────────

    USER {
        uuid        id PK
        uuid        institution_id FK
        string      name
        string      email
        string      role                    "AttendingPathologist | ResidentFellow | PathologyAssistant | SystemAdmin | QAReviewer"
        boolean     is_active
        timestamp   created_at
    }

    %% ─── RELATIONSHIPS ───────────────────────────────────────────────────────

    INSTITUTION            ||--o{ INSTITUTION_LICENSE        : "has"
    INSTITUTION            ||--o{ CASE                       : "has"
    INSTITUTION            ||--o{ USER                       : "has"
    INSTITUTION            ||--o{ INSTITUTION_CUSTOM_RULE    : "configures"

    SYNOPTIC_TEMPLATE      ||--o{ TEMPLATE_SECTION           : "contains"
    SYNOPTIC_TEMPLATE      ||--o{ TEMPLATE_VALIDATION_RULE   : "has"
    SYNOPTIC_TEMPLATE      }o--o| SYNOPTIC_TEMPLATE          : "superseded_by"
    TEMPLATE_SECTION       ||--o{ TEMPLATE_FIELD             : "contains"
    TEMPLATE_FIELD         ||--o{ TERMINOLOGY_MAPPING        : "mapped via"

    CASE                   ||--o{ SPECIMEN                   : "has"
    CASE                   ||--o{ LIS_EVENT                  : "receives"
    CASE                   ||--o{ SYNOPTIC_REPORT            : "has"
    CASE                   }o--|| USER                       : "signed out by"

    SPECIMEN               ||--o{ PROTOCOL_PRESELECTION      : "gets"
    PROTOCOL_PRESELECTION  }o--|| SYNOPTIC_TEMPLATE          : "suggests"
    PROTOCOL_PRESELECTION  }o--|| SYNOPTIC_TEMPLATE          : "final"

    SYNOPTIC_REPORT        ||--o{ SYNOPTIC_VERSION           : "has versions"
    SYNOPTIC_REPORT        }o--|| SYNOPTIC_VERSION           : "active version"
    SYNOPTIC_REPORT        ||--o{ SYNOPTIC_APPROVAL          : "goes through"
    SYNOPTIC_REPORT        }o--|| USER                       : "created by"

    SYNOPTIC_VERSION       }o--|| SYNOPTIC_TEMPLATE          : "uses"
    SYNOPTIC_VERSION       ||--o{ SYNOPTIC_FIELD_VALUE       : "has"
    SYNOPTIC_VERSION       ||--|{ AI_CONFIDENCE_SNAPSHOT     : "has"
    SYNOPTIC_VERSION       }o--o| LIS_EVENT                  : "triggered by gross"
    SYNOPTIC_VERSION       }o--o| LIS_EVENT                  : "triggered by micro"
    SYNOPTIC_VERSION       }o--|| USER                       : "created by"

    SYNOPTIC_FIELD_VALUE   }o--|| TEMPLATE_FIELD             : "defined by"
    SYNOPTIC_FIELD_VALUE   }o--o| USER                       : "confirmed by"

    AUDIT_LOG              }o--|| USER                       : "performed by"
    AUDIT_LOG              }o--o| SYNOPTIC_VERSION           : "references"
